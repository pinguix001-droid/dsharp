  <style>
  * { box-sizing: border-box; }
  html, body { height: 100%; margin: 0; padding: 0; overflow: hidden; }
  body {
    font-family: 'Exo 2', sans-serif;
    background: #0a0a1a;
    color: #fff;
  }

  #game-wrapper {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }

  /* Animated background */
  .bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,255,180,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,255,180,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    animation: gridMove 20s linear infinite;
    pointer-events: none;
  }
  @keyframes gridMove {
    0% { background-position: 0 0; }
    100% { background-position: 0 40px; }
  }

  /* Highway */
  #highway {
    position: relative;
    flex: 1;
    display: flex;
    align-items: flex-start;
    overflow: hidden;
  }

  .lane {
    flex: 1;
    height: 100%;
    position: relative;
    border-right: 1px solid rgba(255,255,255,0.06);
  }
  .lane:last-child { border-right: none; }

  /* Lane glow at bottom */
  .lane-glow {
    position: absolute;
    bottom: 0;
    left: 0; right: 0;
    height: 80px;
    border-radius: 50%;
    opacity: 0;
    transition: opacity 0.1s;
    pointer-events: none;
  }
  .lane.active .lane-glow { opacity: 1; }

  /* Note blocks */
  .note-block {
    position: absolute;
    left: 10%;
    width: 80%;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Orbitron', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    transition: box-shadow 0.05s;
    border: 1px solid rgba(255,255,255,0.3);
    cursor: default;
    user-select: none;
  }

  /* Hit zone */
  #hit-zone {
    position: absolute;
    bottom: 80px;
    left: 0; right: 0;
    height: 6px;
    background: linear-gradient(90deg, transparent, rgba(0,255,180,0.8), transparent);
    box-shadow: 0 0 20px rgba(0,255,180,0.5);
    z-index: 10;
    pointer-events: none;
  }

  /* Hit buttons at bottom */
  #hit-buttons {
    display: flex;
    gap: 0;
    padding: 12px 0 12px;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(10px);
    border-top: 1px solid rgba(255,255,255,0.1);
    z-index: 20;
    position: relative;
  }

  .hit-btn {
    flex: 1;
    height: 56px;
    border-radius: 12px;
    margin: 0 6px;
    border: 2px solid rgba(255,255,255,0.2);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-family: 'Orbitron', monospace;
    font-size: 13px;
    font-weight: 700;
    transition: all 0.08s;
    position: relative;
    overflow: hidden;
    cursor: default;
  }

  .hit-btn .note-label { font-size: 9px; opacity: 0.7; margin-top: 2px; font-family: 'Exo 2', sans-serif; }

  .hit-btn.lit {
    transform: scale(1.05);
    border-color: rgba(255,255,255,0.8);
    box-shadow: 0 0 20px var(--btn-color);
  }

  /* HUD */
  #hud {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 16px;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    z-index: 20;
    position: relative;
    flex-shrink: 0;
  }

  #score-display {
    font-family: 'Orbitron', monospace;
    font-size: 22px;
    font-weight: 900;
    color: #00ffb4;
    text-shadow: 0 0 15px rgba(0,255,180,0.8);
  }

  #combo-display {
    font-family: 'Orbitron', monospace;
    font-size: 14px;
    color: #ff6b35;
    text-shadow: 0 0 10px rgba(255,107,53,0.8);
  }

  #song-info {
    text-align: center;
    flex: 1;
    padding: 0 12px;
  }
  #song-title {
    font-family: 'Orbitron', monospace;
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  #song-progress-bar {
    height: 3px;
    background: rgba(255,255,255,0.15);
    border-radius: 2px;
    margin-top: 4px;
    overflow: hidden;
  }
  #song-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #00ffb4, #00bfff);
    border-radius: 2px;
    width: 0%;
    transition: width 0.3s;
  }

  #pitch-meter {
    width: 100px;
    text-align: right;
  }
  #pitch-value {
    font-family: 'Orbitron', monospace;
    font-size: 11px;
    color: #aaa;
  }
  #detected-note {
    font-family: 'Orbitron', monospace;
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    min-height: 24px;
  }

  /* Overlays */
  .overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(8px);
    z-index: 100;
  }

  .overlay h1 {
    font-family: 'Orbitron', monospace;
    font-size: 36px;
    font-weight: 900;
    background: linear-gradient(135deg, #00ffb4, #00bfff, #ff6b35);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-align: center;
    margin-bottom: 8px;
  }

  .overlay p {
    color: rgba(255,255,255,0.6);
    font-size: 14px;
    text-align: center;
    max-width: 300px;
    line-height: 1.6;
  }

  .btn-primary {
    margin-top: 24px;
    padding: 14px 36px;
    background: linear-gradient(135deg, #00ffb4, #00bfff);
    color: #0a0a1a;
    border: none;
    border-radius: 30px;
    font-family: 'Orbitron', monospace;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 1px;
  }
  .btn-primary:hover {
    transform: scale(1.05);
    box-shadow: 0 0 30px rgba(0,255,180,0.6);
  }

  .btn-secondary {
    margin-top: 12px;
    padding: 10px 28px;
    background: transparent;
    color: rgba(255,255,255,0.6);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 30px;
    font-family: 'Exo 2', sans-serif;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-secondary:hover {
    border-color: rgba(255,255,255,0.5);
    color: #fff;
  }

  /* Song select */
  .song-card {
    width: 280px;
    padding: 14px 18px;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.05);
    cursor: pointer;
    transition: all 0.2s;
    margin: 6px 0;
  }
  .song-card:hover, .song-card.selected {
    border-color: rgba(0,255,180,0.5);
    background: rgba(0,255,180,0.08);
    transform: translateX(4px);
  }
  .song-card .s-title { font-weight: 600; font-size: 15px; }
  .song-card .s-info { font-size: 11px; opacity: 0.5; margin-top: 3px; }
  .song-card .s-diff {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 10px;
    font-size: 10px;
    font-weight: 600;
    margin-top: 5px;
  }

  /* Hit feedback */
  .hit-feedback {
    position: absolute;
    left: 50%;
    top: 40%;
    transform: translateX(-50%);
    font-family: 'Orbitron', monospace;
    font-size: 28px;
    font-weight: 900;
    pointer-events: none;
    z-index: 50;
    animation: feedbackAnim 0.6s ease-out forwards;
  }
  @keyframes feedbackAnim {
    0% { opacity: 1; transform: translateX(-50%) scale(1.2) translateY(0); }
    100% { opacity: 0; transform: translateX(-50%) scale(0.8) translateY(-60px); }
  }

  /* Mic indicator */
  #mic-indicator {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: #ff4444;
    display: inline-block;
    margin-right: 6px;
    transition: background 0.2s;
  }
  #mic-indicator.active { background: #00ff88; box-shadow: 0 0 8px #00ff88; animation: pulse 1s infinite; }
  @keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.5; } }

  /* Volume bar */
  #vol-bar-bg {
    width: 60px; height: 4px;
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
    overflow: hidden;
    display: inline-block;
    vertical-align: middle;
    margin-left: 4px;
  }
  #vol-bar { height: 100%; width: 0%; background: #00ffb4; border-radius: 2px; transition: width 0.05s; }

  /* Scroll songs */
  #songs-list { max-height: 220px; overflow-y: auto; width: 100%; display: flex; flex-direction: column; align-items: center; padding: 0 8px; }
  #songs-list::-webkit-scrollbar { width: 4px; }
  #songs-list::-webkit-scrollbar-track { background: transparent; }
  #songs-list::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 2px; }

  .stars { color: #ffd700; font-size: 13px; }

  /* Streak fire */
  #streak-fire {
    font-size: 20px;
    opacity: 0;
    transition: opacity 0.3s;
    margin-left: 6px;
  }
  #streak-fire.show { opacity: 1; }
</style>
