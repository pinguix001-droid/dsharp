// ── AUDIO / PITCH ─────────────────────────────────────────────────────────────
async function initMic() {
  try {
    if (!navigator.mediaDevices) {
      showError('❌ Tarayıcınız mikrofon desteklemiyor.');
      return false;
    }
    
    console.log('Mikrofon izni isteniyor...');
    const stream = await navigator.mediaDevices.getUserMedia({ 
      audio: { 
        echoCancellation: false, 
        noiseSuppression: false, 
        autoGainControl: false 
      } 
    });
    
    console.log('Mikrofon izni verildi!', stream);
    if (!stream || stream.getTracks().length === 0) {
      showError('❌ Mikrofon akışı başlatılamadı.');
      return false;
    }
    
    micStream = stream;
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    analyser = audioCtx.createAnalyser();
    analyser.fftSize = 4096;
    analyser.smoothingTimeConstant = 0.85;
    const src = audioCtx.createMediaStreamSource(stream);
    src.connect(analyser);
    document.getElementById('mic-indicator').classList.add('active');
    startPitchDetection();
    console.log('Pitch detection başladı');
    return true;
  } catch(e) {
    console.error('Mikrofon hatası:', e.name, e.message);
    let errorMsg = '❌ Mikrofon erişimi reddedildi.';
    if (e.name === 'NotAllowedError') {
      errorMsg = '❌ Mikrofon izni verilmedi!\n\nTarayıcı menüsünden:\n1. Adres çubuğunun solunda kamera/mikrofon simgesini klik et\n2. "Mikrofon" → "İzin Ver" seç\n3. Sonra "OYNA" tuşuna tekrar bas';
    }
    if (e.name === 'NotFoundError') errorMsg = '❌ Bilgisayarına mikrofon takılı değil.';
    if (e.name === 'NotReadableError') errorMsg = '❌ Mikrofon başka program tarafından kullanılıyor.\n\nZoom, Teams veya başka uygulamayı kapat.';
    showError(errorMsg);
    return false;
  }
}

function startPitchDetection() {
  const bufLen = analyser.fftSize;
  const buf = new Float32Array(bufLen);
  function loop() {
    analyser.getFloatTimeDomainData(buf);
    // RMS for volume
    let rms = 0;
    for (let i = 0; i < bufLen; i++) rms += buf[i] * buf[i];
    rms = Math.sqrt(rms / bufLen);
    volLevel = Math.min(1, rms * 8);
    document.getElementById('vol-bar').style.width = (volLevel * 100) + '%';

    if (rms > 0.01) {
      const freq = autoCorrelate(buf, audioCtx.sampleRate);
      if (freq > 60 && freq < 1200) {
        detectedFreq = freq;
        const note = freqToNote(freq);
        detectedNote = note;
        document.getElementById('detected-note').textContent = note;
        document.getElementById('pitch-value').textContent = Math.round(freq) + ' Hz';
        if (gameState === 'playing') checkHit(note, freq);
      } else {
        detectedNote = null;
        detectedFreq = 0;
        document.getElementById('detected-note').textContent = '—';
        document.getElementById('pitch-value').textContent = '— Hz';
      }
    } else {
      detectedNote = null;
      document.getElementById('detected-note').textContent = '—';
      document.getElementById('vol-bar').style.width = '0%';
    }
    pitchDetectionLoop = requestAnimationFrame(loop);
  }
  loop();
}

// YIN-like autocorrelation
function autoCorrelate(buf, sampleRate) {
  const SIZE = buf.length;
  const rms = Math.sqrt(buf.reduce((s,v)=>s+v*v,0)/SIZE);
  if (rms < 0.008) return -1;
  let r1=0, r2=SIZE-1;
  for (let i=0;i<SIZE/2;i++) if(Math.abs(buf[i])<0.2){r1=i;break;}
  for (let i=1;i<SIZE/2;i++) if(Math.abs(buf[SIZE-i])<0.2){r2=SIZE-i;break;}
  const buf2 = buf.slice(r1,r2);
  const c = new Array(buf2.length).fill(0);
  for (let i=0;i<buf2.length;i++) for (let j=0;j<buf2.length-i;j++) c[i]+=buf2[j]*buf2[j+i];
  let d=0;
  while (c[d]>c[d+1]) d++;
  let maxVal=-1, maxPos=-1;
  for (let i=d;i<buf2.length;i++) if(c[i]>maxVal){maxVal=c[i];maxPos=i;}
  let T0=maxPos;
  const x1=c[T0-1],x2=c[T0],x3=c[T0+1];
  const a=(x1+x3-2*x2)/2, b=(x3-x1)/2;
  if (a) T0 -= b/(2*a);
  return sampleRate/T0;
}

function freqToNote(freq) {
  const notes = Object.entries(NOTE_FREQS);
  let best = null, bestDiff = Infinity;
  for (const [name, f] of notes) {
    const diff = Math.abs(Math.log2(freq/f));
    if (diff < bestDiff) { bestDiff = diff; best = name; }
  }
  return best;
}

function noteToLane(noteName) {
  if (!noteName) return -1;
  const letter = noteName.replace(/[0-9]/g,'');
  if (letter === 'C') return 0;
  if (letter === 'D') return 1;
  if (letter === 'E') return 2;
  if (letter === 'F' || letter === 'G') return 3;
  if (letter === 'A' || letter === 'B') return 4;
  return -1;
}

// ── GAME LOGIC ────────────────────────────────────────────────────────────────
async function startGame() {
  if (!selectedSong) return;

  // Init mic first - BEFORE hiding overlays
  if (!audioCtx) {
    const ok = await initMic();
    if (!ok) {
      showError('Mikrofon erişimi reddedildi. Lütfen izin verin ve tekrar deneyin.');
      return;
    }
  }

  // NOW hide overlays and start
  showOverlay(null);
  ['start-overlay','song-select-overlay','result-overlay'].forEach(o => {
    document.getElementById(o).style.display = 'none';
  });

  // Reset state
  score = 0; combo = 1; maxCombo = 1; hits = 0; misses = 0;
  currentNoteIndex = 0;
  noteObjects = [];
  hitCooldown = {};
  gameState = 'playing';
  totalNotes = selectedSong.notes.length;

  document.getElementById('score-display').textContent = '0';
  document.getElementById('combo-display').innerHTML = 'COMBO x1 <span id="streak-fire">🔥</span>';
  document.getElementById('song-title').textContent = selectedSong.title + ' — ' + selectedSong.artist;
  document.getElementById('song-progress-fill').style.width = '0%';

  // Schedule notes
  songNotes = selectedSong.notes.map((n, idx) => {
    // Calculate time offset: each note comes after previous note's duration
    let t = 0;
    for (let i = 0; i < idx; i++) t += selectedSong.notes[i].dur + 80;
    return { ...n, time: t, id: idx, hit: false, missed: false };
  });

  highwayHeight = document.getElementById('highway').offsetHeight;
  songStartTime = performance.now();
  animStart = performance.now();

  // Clear old notes
  document.querySelectorAll('.note-block').forEach(n => n.remove());

  requestAnimationFrame(gameFrame);
}

function gameFrame(timestamp) {
  if (gameState !== 'playing') return;

  const elapsed = timestamp - songStartTime;
  highwayHeight = document.getElementById('highway').offsetHeight;

  // Spawn new notes
  while (currentNoteIndex < songNotes.length) {
    const sn = songNotes[currentNoteIndex];
    // Spawn note early enough so it travels to hit zone
    const travelTime = (highwayHeight - HIT_ZONE_BOTTOM) / NOTE_SPEED * 1000;
    if (elapsed >= sn.time - travelTime) {
      spawnNote(sn);
      currentNoteIndex++;
    } else {
      break;
    }
  }

  // Move existing notes
  const noteEls = document.querySelectorAll('.note-block');
  noteEls.forEach(el => {
    const spawnY = parseFloat(el.dataset.spawnY);
    const elapsed2 = timestamp - parseFloat(el.dataset.spawnTime);
    const y = spawnY + elapsed2 * NOTE_SPEED / 1000;
    el.style.top = y + 'px';

    const noteId = parseInt(el.dataset.noteId);
    const sn = songNotes[noteId];

    // Miss detection: passed hit zone
    if (!sn.hit && !sn.missed) {
      if (y > highwayHeight - HIT_ZONE_BOTTOM + NOTE_HEIGHT) {
        sn.missed = true;
        misses++;
        combo = 1;
        updateComboDisplay();
        el.style.opacity = '0.2';
        showFeedback('MISS', '#ff4444');
        setTimeout(() => el.remove(), 400);
      }
    }

    // Remove far offscreen
    if (y > highwayHeight + 50) el.remove();
  });

  // Progress bar
  const totalDur = songNotes[songNotes.length-1].time + 500;
  document.getElementById('song-progress-fill').style.width = Math.min(100, elapsed / totalDur * 100) + '%';

  // End check
  if (elapsed > songNotes[songNotes.length-1].time + 2000 && currentNoteIndex >= songNotes.length) {
    const remaining = document.querySelectorAll('.note-block').length;
    if (remaining === 0) {
      endGame();
      return;
    }
  }

  requestAnimationFrame(gameFrame);
}

function spawnNote(sn) {
  const lane = document.getElementById(`lane-${sn.lane}`);
  if (!lane) return;
  const el = document.createElement('div');
  el.className = 'note-block';
  el.style.height = NOTE_HEIGHT + 'px';
  el.style.top = '-50px';
  el.style.background = LANE_COLORS[sn.lane] + '33';
  el.style.borderColor = LANE_COLORS[sn.lane] + '99';
  el.style.color = LANE_COLORS[sn.lane];
  el.style.boxShadow = `0 0 10px ${LANE_COLORS[sn.lane]}44`;
  el.textContent = sn.note;
  el.dataset.noteId = sn.id;
  el.dataset.lane = sn.lane;
  el.dataset.spawnTime = performance.now();
  el.dataset.spawnY = -50;
  lane.appendChild(el);
}

function checkHit(noteName, freq) {
  const lane = noteToLane(noteName);
  if (lane < 0) return;

  // Cooldown per lane to avoid rapid multi-hits
  const now = performance.now();
  if (hitCooldown[lane] && now - hitCooldown[lane] < 300) return;

  // Find a note in hit zone for this lane
  const laneEl = document.getElementById(`lane-${lane}`);
  if (!laneEl) return;
  const noteEls = laneEl.querySelectorAll('.note-block');
  const hitZoneY = highwayHeight - HIT_ZONE_BOTTOM;

  for (const el of noteEls) {
    const topY = parseFloat(el.style.top);
    const noteId = parseInt(el.dataset.noteId);
    const sn = songNotes[noteId];
    if (!sn || sn.hit || sn.missed) continue;

    if (topY >= hitZoneY - HIT_WINDOW && topY <= hitZoneY + NOTE_HEIGHT) {
      // Hit!
      sn.hit = true;
      hits++;
      combo++;
      if (combo > maxCombo) maxCombo = combo;
      hitCooldown[lane] = now;

      const points = 100 * Math.min(combo, 8);
      score += points;

      document.getElementById('score-display').textContent = score.toLocaleString();
      updateComboDisplay();

      // Visual feedback
      el.style.background = LANE_COLORS[lane] + '88';
      el.style.boxShadow = `0 0 30px ${LANE_COLORS[lane]}`;
      lightLane(lane);
      showFeedback(combo > 5 ? 'PERFECT! 🔥' : 'NICE! ✓', LANE_COLORS[lane]);
      setTimeout(() => el.remove(), 150);
      break;
    }
  }
}

function lightLane(lane) {
  const laneEl = document.getElementById(`lane-${lane}`);
  laneEl.classList.add('active');
  const btn = document.getElementById(`hit-btn-${lane}`);
  btn.classList.add('lit');
  setTimeout(() => {
    laneEl.classList.remove('active');
    btn.classList.remove('lit');
  }, 200);
}

function updateComboDisplay() {
  const fire = combo >= 5 ? '🔥' : '';
  document.getElementById('combo-display').innerHTML = `COMBO x${combo} ${fire}`;
}

function showFeedback(text, color) {
  const el = document.createElement('div');
  el.className = 'hit-feedback';
  el.style.color = color;
  el.textContent = text;
  document.getElementById('game-wrapper').appendChild(el);
  setTimeout(() => el.remove(), 600);
}

function showError(msg) {
  const overlay = document.createElement('div');
  overlay.className = 'overlay';
  overlay.style.zIndex = '200';
  overlay.innerHTML = `
    <h1 style="color: #ff6b35; font-size: 28px;">⚠️ Hata</h1>
    <p style="max-width: 350px; margin: 16px 0;">${msg}</p>
    <button class="btn-primary" onclick="this.parentElement.remove(); showSongSelect();">Geri Dön</button>
  `;
  document.getElementById('game-wrapper').appendChild(overlay);
}

function endGame() {
  gameState = 'result';
  const accuracy = totalNotes > 0 ? Math.round(hits / totalNotes * 100) : 0;
  let grade, gradeEmoji;
  if (accuracy >= 95) { grade = 'S'; gradeEmoji = '🌟'; }
  else if (accuracy >= 85) { grade = 'A'; gradeEmoji = '⭐'; }
  else if (accuracy >= 70) { grade = 'B'; gradeEmoji = '✨'; }
  else if (accuracy >= 55) { grade = 'C'; gradeEmoji = '🎵'; }
  else { grade = 'D'; gradeEmoji = '🎤'; }

  const stars = accuracy >= 95 
