const LANE_NOTE_NAMES = [["C3","C4","C5"],["D3","D4","D5"],["E3","E4","E5"],["F3","F4","F5","G3","G4","G5"],["A3","A4","A5"]];

// ── STATE ────────────────────────────────────────────────────────────────────
let gameState = "menu"; // menu | playing | result
let selectedSong = null;
let score = 0, combo = 1, maxCombo = 1, hits = 0, misses = 0;
let noteObjects = []; // active note DOM elements
let audioCtx = null, analyser = null, micStream = null;
