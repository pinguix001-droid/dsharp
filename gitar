let highwayHeight = 0;
const NOTE_SPEED = 200; // px per second
const HIT_ZONE_BOTTOM = 80; // px from bottom
const NOTE_HEIGHT = 40;
const HIT_WINDOW = 80; // px tolerance
let animStart = null;

// ── INIT SDK ─────────────────────────────────────────────────────────────────
const defaultConfig = { game_title: "PITCH HERO" };

window.elementSdk.init({
